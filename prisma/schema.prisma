generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  description    String
  type           String
  status         String     @default("active")
  tag            String?
  featured       Boolean    @default(false)
  location       String
  address        String
  mapUrl         String?
  nearbyPlaces   String[]
  developer      String?
  listingType    String   @default("Sale")
  projectStatus  String?
  startingPrice  Float?
  rentalYield    Float?
  yearBuilt      Int?
  completionDate String?
  totalFloors    Int?
  totalUnits     Int?
  images         String[]
  amenities      String[]
  unitTypes      UnitType[]
  inquiries      Inquiry[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@index([type])
  @@index([featured])
  @@index([status, featured])
  @@index([createdAt])
}

model UnitType {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  bedrooms   Int
  bathrooms  Int
  areaSqmMin Float
  areaSqmMax Float?
  parking    Int      @default(1)
  images     String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Inquiry {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String
  message    String
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([propertyId])
  @@index([read])
}
